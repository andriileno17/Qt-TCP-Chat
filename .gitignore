# --- Build Directories ---
# Головна папка збірки, яку ми обговорювали
build/
bin/
lib/

# --- CMake ---
# Тимчасові файли конфігурації CMake
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
install_manifest.txt
Makefile

# --- Qt / IDE (Qt Creator) ---
