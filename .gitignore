*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe

# --- Linux / Fedora Specific ---
# Тимчасові файли текстових редакторів та системи
*~
.directory
.fuse_hidden*
.trash*
.nfs*

# --- IDE specific ---
